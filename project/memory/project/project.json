{
  "schemaVersion": "cofabric.memory.project.v1",
  "name": "NutriTrack",
  "oneLineDescription": "An AI-powered nutrition tracking application designed to help users easily log meals, understand their dietary habits, and improve overall health.",
  "whatItIs": "NutriTrack is an AI-powered nutrition tracking application designed to help users easily log meals, understand their dietary habits, and improve overall health. The product focuses on speed, simplicity, and intelligent automation to reduce the friction typically associated with food tracking.",
  "stack": [
    {
      "name": "next",
      "version": "14.2.5",
      "purpose": "React framework"
    },
    {
      "name": "react",
      "version": "^18",
      "purpose": "UI library"
    },
    {
      "name": "react-dom",
      "version": "^18",
      "purpose": "React DOM rendering"
    },
    {
      "name": "@supabase/supabase-js",
      "version": "^2.39.0",
      "purpose": "Supabase client"
    },
    {
      "name": "openai",
      "version": "^4.28.0",
      "purpose": "OpenAI API integration"
    },
    {
      "name": "tailwindcss",
      "version": "^3.4.1",
      "purpose": "CSS framework"
    }
  ],
  "externalIntegrations": [
    {
      "service": "Supabase",
      "envVars": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY"
      ],
      "clientLocation": null
    },
    {
      "service": "OpenAI",
      "envVars": [
        "OPENAI_API_KEY"
      ],
      "clientLocation": null
    }
  ],
  "coreUserFlows": [
    "User signs up / logs in",
    "Sets basic goals (weight, target calories)",
    "Lands on daily dashboard",
    "Logs a meal (manual or photo)",
    "Views updated nutrition summary",
    "Receives basic feedback"
  ],
  "outOfScope": [
    "Full meal planning",
    "Advanced analytics",
    "Wearable integrations",
    "Social/community features"
  ]
}