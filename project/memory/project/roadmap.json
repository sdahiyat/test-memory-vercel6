  "databaseTablesToCreate": [
    {
      "name": "users",
      "columnsSpecifiedInSpec": [
        {
          "name": "weight",
          "type": "decimal",
          "notes": "user weight for goal setting"
        },
        {
          "name": "target_calories",
          "type": "integer",
          "notes": "daily calorie goal"
        }
      ],
      "schemaDetailsInSpec": false
    },
    {
      "name": "meals",
      "columnsSpecifiedInSpec": [
        {
          "name": "user_id",
          "type": "uuid",
          "notes": "foreign key to users"
        },
        {
          "name": "calories",
          "type": "integer",
          "notes": "meal calorie content"
        },
        {
          "name": "protein",
          "type": "decimal",
          "notes": "protein macronutrient in grams"
        },
        {
          "name": "carbs",
          "type": "decimal",
          "notes": "carbohydrate macronutrient in grams"
        },
        {
          "name": "fats",
          "type": "decimal",
          "notes": "fat macronutrient in grams"
        }
      ],
      "schemaDetailsInSpec": false
    },
    {
      "name": "foods",
      "columnsSpecifiedInSpec": [
        {
          "name": "name",
          "type": "text",
          "notes": "food name for manual entry"
        },
        {
          "name": "calories_per_serving",
          "type": "integer",
          "notes": "calorie content per serving"
        },
        {
          "name": "protein_per_serving",
          "type": "decimal",
          "notes": "protein content per serving"
        },
        {
          "name": "carbs_per_serving",
          "type": "decimal",
          "notes": "carbohydrate content per serving"
        },
        {
          "name": "fats_per_serving",
          "type": "decimal",
          "notes": "fat content per serving"
        }
      ],
      "schemaDetailsInSpec": false
    }
  ],
  "apiEndpointsToBuild": [
    {
      "method": "POST",
      "path": "/api/meals",
      "description": "Log a new meal with nutrition data",
      "authRequired": true
    },
    {
      "method": "GET",
      "path": "/api/meals",
      "description": "Retrieve user's meal history",
      "authRequired": true
    },
    {
      "method": "POST",
      "path": "/api/photos/analyze",
      "description": "Analyze food photo for automatic identification and nutrition estimation",
      "authRequired": true
    },
    {
      "method": "GET",
      "path": "/api/nutrition/daily",
      "description": "Get daily nutrition summary with calories and macros",
      "authRequired": true
    },
    {
      "method": "POST",
      "path": "/api/users/goals",
      "description": "Set user goals for weight and target calories",
      "authRequired": true
    },
    {
      "method": "GET",
      "path": "/api/users/goals",
      "description": "Retrieve user's current goals",
      "authRequired": true
    },
    {
      "method": "GET",
      "path": "/api/foods/search",
      "description": "Search food database for manual entry",
      "authRequired": true
    },
    {
      "method": "GET",
      "path": "/api/foods/recent",
      "description": "Get user's recent/frequent foods for quick entry",
      "authRequired": true
    },
    {
      "method": "GET",
      "path": "/api/progress",
      "description": "Retrieve progress data for charts and history",
      "authRequired": true
    },
    {
      "method": "GET",
      "path": "/api/insights",
      "description": "Generate daily/weekly nutrition insights and suggestions",
      "authRequired": true
    }
  ],
  "openQuestions": [
    "What specific micronutrients should be tracked in the optional micronutrient feature?",
    "How should portion sizes be standardized and measured?",
    "What constitutes 'limited AI usage' in the free tier?",
    "How should the food database be populated and maintained?",
    "What specific goal types beyond weight loss, maintenance, and muscle gain should be supported?",
    "How should progress be measured and what metrics should be tracked over time?",
    "What triggers should be used for habit detection in insights?"
  ]
}